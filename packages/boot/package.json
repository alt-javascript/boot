    "config": "^4.4.1",
    "c8": "^7.11.0",
    "eslint": "^7.30.0",
    "eslint-config-airbnb-base": "^14.2.1",
    "eslint-plugin-import": "^2.23.4",
    "mocha": "^11.0.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/alt-javascript/boot.git",
