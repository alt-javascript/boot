{
  "name": "@alt-javascript/boot-vue",
  "version": "3.0.5",
  "description": "Vue 3 integration for @alt-javascript boot \u2014 bridges CDI services into Vue's reactive system",
  "type": "module",
  "main": "index.js",
  "exports": {
    ".": "./index.js"
  },
  "author": "Craig Parravicini",
  "contributors": [
    "Claude (Anthropic)"
  ],
  "keywords": [
    "alt-javascript",
    "vue",
    "boot",
    "cdi",
    "dependency-injection",
    "reactive"
  ],
  "publishConfig": {
    "registry": "https://registry.npmjs.org/",
    "access": "public"
  },
  "scripts": {
    "build": "rollup -c rollup.config.js",
    "prepublishOnly": "npm run build",
    "test": "mocha --recursive test/**/*.spec.js"
