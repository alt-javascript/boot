    "mocha": "^11.7.5"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/alt-javascript/boot.git",
    "directory": "packages/boot-vue"
  },
  "homepage": "https://github.com/alt-javascript/boot/tree/main/packages/boot-vue#readme",
  "bugs": {
