    "lodash": "^4.17.21"
  },
  "devDependencies": {
    "@alt-javascript/boot": "3.0.0-alpha.0",
    "c8": "^7.11.0",
    "chai": "^4.3.4",
    "chai-as-promised": "^7.1.1",
    "config": "^4.4.1",
    "eslint": "^7.30.0",
    "eslint-config-airbnb-base": "^14.2.1",
    "eslint-plugin-import": "^2.23.4",
    "mocha": "^11.7.5",
    "rollup": "^4.59.0",
    "rollup-plugin-esm-import-to-url": "^2.1.0",
    "uuid": "^8.3.2"
  }
